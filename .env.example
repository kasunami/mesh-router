MESH_ROUTER_MESHBENCH_SYNC_ENABLED=false
MESH_ROUTER_LEASE_TOKEN_SECRET=replace-with-random-secret
MESH_ROUTER_SWAP_AUTH_TOKEN=replace-with-worker-swap-token
MESH_ROUTER_ALLOW_DEV_SECRETS=0
MESH_ROUTER_ROUTER_PUBLIC_BASE_URL=http://mesh-router.example:4010
MESH_ROUTER_OPPORTUNISTIC_HOSTS=
MESH_ROUTER_VLM_LANE_HOST_REF=model-router
MESH_ROUTER_VLM_LANE_NAME=vlm-router
