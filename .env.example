MESH_ROUTER_DEFAULT_OWNER=mesh-router
MESH_ROUTER_DEFAULT_JOB_TYPE=openai_proxy
MESH_ROUTER_SYNC_INTERVAL_SECONDS=30
MESH_ROUTER_PROBE_INTERVAL_SECONDS=15

